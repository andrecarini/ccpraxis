FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    ca-certificates \
    build-essential \
    jq \
    unzip \
    openssh-client \
    perl \
    procps \
    socat \
    && rm -rf /var/lib/apt/lists/*

# Container runs as root.
#
# Rationale: this is a rootless-Podman dev sandbox. Container UID 0 (root)
# is mapped to the host user via Podman's user namespace, so:
#   - Files written to bind-mounted /project come out owned by the host
#     user on the host (no chown dance required).
#   - "root" inside the container is not host root — a container escape
#     would land as the unprivileged host user.
#   - The agent gets full power inside (apt-get / npm -g / pip global etc.)
#     without any sudo workaround.
# We do NOT create a non-root user.

# Install Claude Code via native installer (installs to /root/.local/bin)
ARG CLAUDE_VERSION=latest
RUN curl -fsSL https://claude.ai/install.sh | bash -s -- ${CLAUDE_VERSION}
ENV PATH="/root/.local/bin:${PATH}"

# Terminal — enable 24-bit color support (matches host terminal)
ENV TERM=xterm-256color
ENV COLORTERM=truecolor

# Tell Claude Code this is a sandbox so it allows --dangerously-skip-permissions
# even though the container runs as root. Without this, Claude Code refuses to
# start with --dangerously-skip-permissions when uid=0 and the whole "full
# autonomy" model breaks. See anthropics/claude-code#9184.
ENV IS_SANDBOX=1

# Supply chain hardening — env vars take effect whenever runtimes are installed
ENV npm_config_ignore_scripts=true
ENV NODE_OPTIONS="--dns-result-order=ipv4first"

# Git defaults
RUN git config --global core.autocrlf input \
    && git config --global init.defaultBranch main

WORKDIR /project
# Entrypoint: container/heartbeat.sh (extracted from the former inline one-liner
# so its reap decision is unit-testable — plugins/sandbox/tests/t/08-reap-decision.t).
#   1. Spawn socat bridges for ports 9000-9009 ONLY (0.0.0.0:N -> 127.0.0.1:N)
#      so the host-browser OAuth callback redirect reaches Claude Code's
#      loopback-bound listener. The launcher ALSO publishes 9010-9019, but those
#      are deliberately left un-bridged (a server binds 0.0.0.0:N there directly,
#      no socat to collide with) — heartbeat.sh does NOT bridge them.
#   2. Heartbeat keep-alive. Container survives while /tmp/.launcher-alive was
#      mtime-touched within HB=300s (the host manager `claude-sandbox` refreshes
#      it every 2 min). A 10s startup grace lets the manager land the first touch.
#      If the sentinel goes stale (manager terminal closed / laptop asleep):
#        - no live butler run  -> self-reap within ~5 min (no orphan containers),
#          exactly as before;
#        - a live run (/tmp/.butler-busy fresh OR a live coordinator) -> signal a
#          graceful fleet shutdown (touch each blueprint's runs/.shutdown, the A4
#          gate) and wait GRACE_SHUTDOWN=300s for coordinators to park cleanly,
#          reaping as soon as the run clears or at the grace deadline (B6).
#      The container does NOT watch claude itself — its life is bound to the
#      manager heartbeat, not to any claude process. Multiple (or zero) connector
#      sessions are fine.
COPY heartbeat.sh /usr/local/bin/sandbox-heartbeat
RUN chmod +x /usr/local/bin/sandbox-heartbeat
ENTRYPOINT ["/usr/local/bin/sandbox-heartbeat"]
