FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    ca-certificates \
    build-essential \
    jq \
    unzip \
    openssh-client \
    perl \
    procps \
    socat \
    && rm -rf /var/lib/apt/lists/*

# Container runs as root.
#
# Rationale: this is a rootless-Podman dev sandbox. Container UID 0 (root)
# is mapped to the host user via Podman's user namespace, so:
#   - Files written to bind-mounted /project come out owned by the host
#     user on the host (no chown dance required).
#   - "root" inside the container is not host root — a container escape
#     would land as the unprivileged host user.
#   - The agent gets full power inside (apt-get / npm -g / pip global etc.)
#     without any sudo workaround.
# We do NOT create a non-root user.

# Install Claude Code via native installer (installs to /root/.local/bin)
ARG CLAUDE_VERSION=latest
RUN curl -fsSL https://claude.ai/install.sh | bash -s -- ${CLAUDE_VERSION}
ENV PATH="/root/.local/bin:${PATH}"

# Terminal — enable 24-bit color support (matches host terminal)
ENV TERM=xterm-256color
ENV COLORTERM=truecolor

# Tell Claude Code this is a sandbox so it allows --dangerously-skip-permissions
# even though the container runs as root. Without this, Claude Code refuses to
# start with --dangerously-skip-permissions when uid=0 and the whole "full
# autonomy" model breaks. See anthropics/claude-code#9184.
ENV IS_SANDBOX=1

# Supply chain hardening — env vars take effect whenever runtimes are installed
ENV npm_config_ignore_scripts=true
ENV NODE_OPTIONS="--dns-result-order=ipv4first"

# Git defaults
RUN git config --global core.autocrlf input \
    && git config --global init.defaultBranch main

WORKDIR /project
# Entrypoint:
#   1. Spawn socat bridges for ports 9000-9009 ONLY. Each forwards
#      0.0.0.0:N -> 127.0.0.1:N so the OAuth callback redirect from the
#      host browser (Podman has already port-forwarded the host's
#      9000-9009 to the container) reaches Claude Code's loopback-bound
#      listener. socat starts even if nothing is yet listening on
#      127.0.0.1:N -- early connections drop until Claude Code's listener
#      appears, then forward cleanly. Backgrounded; children get SIGHUP
#      and die when the bash below exits.
#      NOTE: the launcher ALSO publishes 9010-9019, but those are
#      deliberately left un-bridged here -- a server binds 0.0.0.0:N on
#      them directly with no socat to collide with. Do not extend this
#      loop to cover them.
#   2. Heartbeat-only keep-alive loop. Container survives while
#      /tmp/.launcher-alive has been mtime-touched within the last
#      HB=300 seconds (5 min staleness window). The manager-mode
#      `claude-sandbox` launcher running on the host refreshes the
#      sentinel every 2 minutes via `podman/docker exec ... touch ...`.
#      If the manager terminal closes or the laptop goes to sleep without
#      refresh, the sentinel goes stale and the container self-reaps
#      within ~5 min — no orphan containers. A 10s startup grace gives
#      the manager time to land the FIRST touch immediately after start.
#
#      Container does NOT watch claude itself — claude is launched in a
#      separate connector-mode terminal via a second `claude-sandbox`
#      invocation, and multiple concurrent connectors (or none at all)
#      are fine. The container's life is bound to the manager's
#      heartbeat, not to any claude process.
ENTRYPOINT ["/bin/bash", "-c", "for p in {9000..9009}; do socat TCP-LISTEN:$p,fork,reuseaddr TCP:127.0.0.1:$p 2>/dev/null & done; START=$SECONDS; ALIVE=/tmp/.launcher-alive; HB=300; GRACE=10; while true; do EL=$((SECONDS-START)); if [ $EL -lt $GRACE ]; then sleep 1; continue; fi; if [ -f $ALIVE ]; then LAST=$(stat -c %Y $ALIVE 2>/dev/null || echo 0); NOW=$(date +%s); if [ $((NOW-LAST)) -lt $HB ]; then sleep 10; continue; fi; fi; break; done"]
