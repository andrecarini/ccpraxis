{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "CLAUDE_CODE_NEW_INIT": "1",
    "DISABLE_UPGRADE_COMMAND": "1",
    "MAX_THINKING_TOKENS": "100000",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(bash \"$HOME/.claude/claude-code-config/scripts/sync-export.sh\":*)",
      "Bash(bash \"$HOME/.claude/claude-code-config/scripts/sensitive-check.sh\":*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable"
  },
  "statusLine": {
    "type": "command",
    "command": "perl \"$HOME/.claude/claude-code-config/scripts/statusline.pl\""
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "showThinkingSummaries": true
}
