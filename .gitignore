# Never commit sensitive data
*.credentials*
*.key
*.pem
*.secret
deploy_key*
.statusline_usage_cache.json
.backup-preferences.json
.claude/settings.local.json
# Install-specific enabledPlugins (references the local @ccpraxis-local marketplace);
# Claude Code rewrites it on every plugin toggle — machine state, not shared config.
.claude/settings.json
.claude-plans/
.ccpraxis-local-data/

.claude/backup-metadata.json

.claude/backup-cache/

.claude/scheduled_tasks.lock
.claude/worktrees/

# Transient pre-merge backups created by skills/backup/scripts/ccpraxis-helpers.pl settings-export-merge
*.pre-merge.*

# Machine-specific perl shim generated by host-tools/ccpraxis-install.pl (points
# at the local perl.exe path; never the same across machines)
host-tools/bin/perl.cmd

# Added by claude-sandbox bootstrap
deploy_key
